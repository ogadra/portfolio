{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "portfolio",
	"compatibility_date": "2026-07-03",
	"compatibility_flags": ["nodejs_compat"],
	"kv_namespaces": [
		{
			"binding": "GITHUB_CACHE",
		},
	],
	// Refresh the persisted daily commit history twice a day so each day is
	// captured before it rolls out of the GitHub commit-search window.
	"triggers": {
		"crons": ["0 */12 * * *"],
	},
}
