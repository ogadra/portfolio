---
import { getLocale } from '../paraglide/runtime.js';
import BootOverlay from '../components/BootOverlay.astro';
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'ogadra.com' } = Astro.props;
---

<!doctype html>
<html lang={getLocale()}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<link
			rel="preload"
			href="/fonts/Oswald-Medium.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<style is:inline>
			html,
			body {
				background: #000;
			}
			#boot {
				display: flex;
				position: fixed;
				inset: 0;
				z-index: 9998;
				background: #000;
				align-items: center;
				justify-content: center;
				animation: boot-out 0.35s ease-out 1s forwards;
			}
			@keyframes boot-out {
				to {
					opacity: 0;
					visibility: hidden;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				#boot {
					display: none !important;
				}
			}
		</style>
	</head>
	<body>
		<BootOverlay />
		<div class="content-root">
			<slot />
		</div>
	</body>
</html>

<style>
	.content-root {
		position: fixed;
		inset: 0;
		z-index: 10;
		overflow-y: auto;
	}
</style>
