---
interface Props {
	subjects: readonly string[];
}

const { subjects } = Astro.props;
---

<p data-typewriter data-subjects={JSON.stringify(subjects)}>
	<span class="first"></span><span class="rest"></span>
</p>

<script>
	import { APPEND_MS, DISPLAY_MS, EMPTY_MS, REMOVE_MS } from "../lib/typewriter-timing";

	const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

	function render(el: HTMLElement, text: string) {
		const first = el.querySelector<HTMLElement>(".first");
		const rest = el.querySelector<HTMLElement>(".rest");
		if (!first || !rest) return;
		first.textContent = text.slice(0, 1);
		rest.textContent = text.slice(1);
	}

	async function typeAndDelete(el: HTMLElement, word: string) {
		for (let i = 0; i < word.length; i++) {
			await sleep(APPEND_MS);
			render(el, word.slice(0, i + 1));
		}
		await sleep(DISPLAY_MS);
		for (let i = word.length; i > 0; i--) {
			await sleep(REMOVE_MS);
			render(el, word.slice(0, i - 1));
		}
		await sleep(EMPTY_MS);
	}

	async function runLoop(el: HTMLElement, subjects: readonly string[]) {
		while (true) {
			for (const s of subjects) {
				await typeAndDelete(el, s);
			}
		}
	}

	for (const el of document.querySelectorAll<HTMLElement>("[data-typewriter]")) {
		const raw = el.dataset.subjects;
		if (!raw) continue;
		const subjects = JSON.parse(raw) as string[];
		runLoop(el, subjects);
	}
</script>

<style>
	.first {
		color: #f092ac;
		font-size: max(4.5vw, 3rem);
	}

	.rest {
		font-size: max(3vw, 2rem);
	}
</style>
