---
interface Props {
	subjects: readonly string[];
}

const { subjects } = Astro.props;
---

<p data-typewriter data-subjects={JSON.stringify(subjects)}></p>

<script>
	const APPEND_MS = 90;
	const REMOVE_MS = 50;
	const DISPLAY_MS = 2000;
	const EMPTY_MS = 100;

	const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

	async function typeAndDelete(el: HTMLElement, word: string) {
		for (let i = 0; i < word.length; i++) {
			await sleep(APPEND_MS);
			el.textContent = word.slice(0, i + 1);
		}
		await sleep(DISPLAY_MS);
		for (let i = word.length; i > 0; i--) {
			await sleep(REMOVE_MS);
			el.textContent = word.slice(0, i - 1);
		}
		await sleep(EMPTY_MS);
	}

	async function runLoop(el: HTMLElement, subjects: readonly string[]) {
		while (true) {
			for (const s of subjects) {
				await typeAndDelete(el, s);
			}
		}
	}

	for (const el of document.querySelectorAll<HTMLElement>('[data-typewriter]')) {
		const raw = el.dataset.subjects;
		if (!raw) continue;
		const subjects = JSON.parse(raw) as string[];
		runLoop(el, subjects);
	}
</script>
