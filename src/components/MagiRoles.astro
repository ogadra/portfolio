---
import type { LanguageShare } from '../lib/githubStats';

interface Props {
	languages: LanguageShare[];
}

const { languages } = Astro.props;

const units = [
	{ code: 'UNIT-01', name: 'FRONT-END', tech: 'TypeScript', fallback: 55 },
	{ code: 'UNIT-02', name: 'BACK-END', tech: 'Go', fallback: 25 },
	{ code: 'UNIT-03', name: 'INFRASTRUCTURE', tech: 'HCL', fallback: 15 },
];

const shareFor = (tech: string) => languages.find((l) => l.name === tech)?.ratio ?? null;
---

<aside class="magi">
	<p class="magi-title">
		<span class="nerv-section-label">Skill Matrix</span>
		<span class="magi-jp">主要技術</span>
	</p>
	{
		units.map((u, i) => {
			const share = shareFor(u.tech);
			return (
				<div class="unit" style={`--sweep-delay:${i * 1.4}s`}>
					<div class="unit-head">
						<span class="unit-code">{u.code}</span>
						<span class="unit-verdict">稼働中</span>
					</div>
					<p class="unit-name">{u.name}</p>
					<p class="unit-tech">{u.tech}</p>
					<div class="unit-meter" aria-hidden="true">
						<span
							class="unit-fill"
							style={`width:${share ?? u.fallback}%; animation-delay:${i * 180}ms`}
						/>
					</div>
					<p class="unit-status">
						{share === null ? 'GITHUB LANG SHARE // --' : `GITHUB LANG SHARE // ${share}%`}
					</p>
				</div>
			);
		})
	}
</aside>

<style>
	.magi {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-width: 0;
	}

	.magi-title {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5rem;
		padding-bottom: 0.35rem;
		border-bottom: 1px solid var(--nerv-line-soft);
	}
	.magi-jp {
		font-family: var(--font-serif-jp);
		font-weight: 900;
		font-size: 0.62rem;
		letter-spacing: 0.3em;
		color: var(--nerv-white);
		opacity: 0.55;
		white-space: nowrap;
	}

	.unit {
		position: relative;
		overflow: hidden;
		padding: 0.7rem 0.8rem 0.8rem;
		border: 1px solid var(--nerv-panel-edge);
		background: linear-gradient(180deg, rgba(20, 20, 20, 0.9), rgba(4, 4, 4, 0.92));
		clip-path: polygon(
			0 0,
			calc(100% - 14px) 0,
			100% 14px,
			100% 100%,
			14px 100%,
			0 calc(100% - 14px)
		);
	}
	/* periodic scan sweep: coarse steps make it read as a machine refresh */
	.unit::after {
		content: '';
		position: absolute;
		inset: -40% 0;
		background: linear-gradient(180deg, transparent, rgba(255, 153, 0, 0.09), transparent);
		transform: translateY(-100%);
		animation: unit-sweep 4.2s steps(9, end) infinite;
		animation-delay: var(--sweep-delay);
		pointer-events: none;
	}
	@keyframes unit-sweep {
		0% {
			transform: translateY(-100%);
		}
		45%,
		100% {
			transform: translateY(100%);
		}
	}

	.unit-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
	}
	.unit-code {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		letter-spacing: 0.3em;
		color: var(--nerv-white);
		opacity: 0.55;
	}
	.unit-verdict {
		font-family: var(--font-serif-jp);
		font-weight: 900;
		font-size: 0.8rem;
		letter-spacing: 0.3em;
		color: var(--nerv-green);
		text-shadow: 0 0 4px rgba(0, 255, 0, 0.4);
	}

	.unit-name {
		font-family: var(--font-display);
		font-size: 1.15rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--nerv-orange);
		margin-top: 0.3rem;
	}
	.unit-tech {
		font-family: var(--font-mono);
		font-size: 0.62rem;
		letter-spacing: 0.2em;
		color: var(--nerv-white);
		opacity: 0.75;
		margin: 0.1rem 0 0.55rem;
	}

	.unit-meter {
		height: 7px;
		background: rgba(255, 153, 0, 0.12);
		overflow: hidden;
	}
	.unit-fill {
		display: block;
		height: 100%;
		background: linear-gradient(90deg, rgba(255, 153, 0, 0.55), var(--nerv-orange));
		transform: scaleX(0);
		transform-origin: left;
		animation: unit-draw 0.9s steps(12, end) forwards;
	}
	@keyframes unit-draw {
		to {
			transform: scaleX(1);
		}
	}

	.unit-status {
		font-family: var(--font-mono);
		font-size: 0.56rem;
		letter-spacing: 0.22em;
		color: var(--nerv-white);
		opacity: 0.55;
		margin-top: 0.5rem;
		font-variant-numeric: tabular-nums;
	}
</style>
