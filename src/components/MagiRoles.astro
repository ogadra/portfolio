---
import type { LanguageShare } from '../lib/githubStats';

interface Props {
	languages: LanguageShare[];
}

const { languages } = Astro.props;

const units = [
	{ code: 'UNIT-01', name: 'FRONT-END', tech: 'TypeScript', accent: 'cyan' },
	{ code: 'UNIT-02', name: 'BACK-END', tech: 'Go', accent: 'orange' },
	{ code: 'UNIT-03', name: 'INFRASTRUCTURE', tech: 'HCL', accent: 'green' },
];

const shareFor = (tech: string) => languages.find((l) => l.name === tech)?.ratio ?? null;
---

<aside class="magi" id="skills">
	<p class="magi-title">
		<span class="nerv-section-label">Skill Matrix</span>
		<span class="magi-jp">主要技術</span>
	</p>
	{
		units.map((u) => {
			const share = shareFor(u.tech);
			return (
				<div class={`unit ${u.accent}`}>
					<div class="unit-head">
						<div class="name-box">
							<span class="reg">Skill Register</span>
							<p class="unit-name">{u.name}</p>
						</div>
						<span class="unit-badge">{u.code}</span>
					</div>
					<div class="rows">
						<div class="row">
							<span>Primary Lang</span>
							<b>{u.tech}</b>
						</div>
						<div class="row">
							<span>GitHub Share</span>
							<b class="num">
								{share === null ? '--' : `${share}%`}
								{share === null ? <i class="na">N/A</i> : <i class="ok">OK</i>}
							</b>
						</div>
						<div class="row">
							<span>Status</span>
							<b class="verdict">稼働中</b>
						</div>
					</div>
					<div class="meter" aria-hidden="true">
						<span class="meter-fill" style={`width:${share ?? 10}%`} />
					</div>
				</div>
			);
		})
	}
</aside>

<style>
	.magi {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-width: 0;
	}

	.magi-title {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5rem;
		padding-bottom: 0.35rem;
		border-bottom: 1px solid var(--nerv-line-soft);
	}
	.magi-jp {
		font-family: var(--font-serif-jp);
		font-weight: 900;
		font-size: 0.62rem;
		letter-spacing: 0.3em;
		color: var(--nerv-white);
		opacity: 0.55;
		white-space: nowrap;
	}

	.unit {
		--accent: var(--nerv-orange);
		--accent-soft: rgba(255, 153, 0, 0.3);
		padding: 0.7rem 0.8rem 0.8rem;
		border: 1px solid var(--accent-soft);
		background: rgba(4, 4, 4, 0.92);
		box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.02);
	}
	.unit.cyan {
		--accent: var(--nerv-cyan);
		--accent-soft: rgba(0, 246, 255, 0.3);
	}
	.unit.green {
		--accent: var(--nerv-green);
		--accent-soft: rgba(0, 255, 0, 0.3);
	}

	.unit-head {
		display: flex;
		justify-content: space-between;
		align-items: stretch;
		gap: 0.5rem;
		margin-bottom: 0.6rem;
	}
	.name-box {
		border: 1px solid var(--accent-soft);
		box-shadow: 0 0 6px color-mix(in srgb, var(--accent) 25%, transparent);
		padding: 0.35rem 0.6rem;
	}
	.reg {
		display: block;
		font-family: var(--font-mono);
		font-size: 0.5rem;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--accent);
		opacity: 0.75;
	}
	.unit-name {
		font-family: var(--font-display);
		font-size: 1rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin-top: 0.15rem;
	}
	.unit-badge {
		display: flex;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 0.56rem;
		letter-spacing: 0.2em;
		padding: 0 0.6em;
		border: 1px solid var(--accent-soft);
		color: var(--accent);
		white-space: nowrap;
	}

	.rows {
		display: flex;
		flex-direction: column;
	}
	.row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5rem;
		padding: 0.35rem 0.1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.07);
	}
	.row span {
		font-family: var(--font-mono);
		font-size: 0.54rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--nerv-white);
		opacity: 0.5;
	}
	.row b {
		font-family: var(--font-mono);
		font-weight: 400;
		font-size: 0.66rem;
		letter-spacing: 0.12em;
		color: var(--nerv-white);
	}
	.row b.num {
		font-variant-numeric: tabular-nums;
	}
	.ok,
	.na {
		font-style: normal;
		font-size: 0.52rem;
		letter-spacing: 0.1em;
		padding: 0.1em 0.45em;
		margin-left: 0.5em;
	}
	.ok {
		background: var(--nerv-green);
		color: #000;
	}
	.na {
		background: rgba(255, 255, 255, 0.25);
		color: #000;
	}
	.verdict {
		font-family: var(--font-serif-jp);
		font-weight: 900;
		color: var(--nerv-green);
		text-shadow: 0 0 4px rgba(0, 255, 0, 0.4);
		letter-spacing: 0.25em;
		animation: nerv-flicker 7s step-end infinite;
	}

	/* segmented meter: discrete blocks instead of a smooth fill */
	.meter {
		height: 8px;
		margin-top: 0.55rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		padding: 1px;
	}
	.meter-fill {
		display: block;
		height: 100%;
		background: repeating-linear-gradient(90deg, var(--accent) 0 6px, transparent 6px 8px);
		transform: scaleX(0);
		transform-origin: left;
		animation: meter-draw 0.9s steps(12, end) forwards;
	}
	@keyframes meter-draw {
		to {
			transform: scaleX(1);
		}
	}
</style>
