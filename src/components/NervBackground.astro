---
const BLIPS = [
	{ x: 22, y: 34, c: 'cyan', d: 0 },
	{ x: 78, y: 26, c: 'orange', d: 1.3 },
	{ x: 66, y: 72, c: 'cyan', d: 2.1 },
	{ x: 34, y: 78, c: 'orange', d: 0.7 },
	{ x: 88, y: 58, c: 'cyan', d: 3.2 },
];
---

<div class="nerv-background" aria-hidden="true">
	<svg class="hex-layer" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
		<defs>
			<pattern id="nerv-hex" patternUnits="userSpaceOnUse" width="90" height="51.96">
				<g fill="none" stroke="var(--nerv-orange)" stroke-width="1">
					<polygon points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"></polygon>
					<polygon
						points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"
						transform="translate(90 0)"></polygon>
					<polygon
						points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"
						transform="translate(0 51.96)"></polygon>
					<polygon
						points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"
						transform="translate(90 51.96)"></polygon>
					<polygon
						points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"
						transform="translate(45 25.98)"></polygon>
				</g>
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill="url(#nerv-hex)"></rect>
	</svg>

	<div class="rings"></div>
	<div class="sweep"></div>

	<div class="blips">
		{BLIPS.map((b) => <span class={b.c} style={`left:${b.x}%; top:${b.y}%; animation-delay:${b.d}s`} />)}
	</div>

	<div class="guide" style="left: 12%"></div>
	<div class="guide" style="left: 50%"></div>
	<div class="guide" style="left: 88%"></div>
</div>

<style>
	.nerv-background {
		position: fixed;
		inset: 0;
		z-index: 1;
		overflow: hidden;
		pointer-events: none;
	}

	.hex-layer {
		position: absolute;
		inset: 0;
		animation: hex-breathe 8s ease-in-out infinite;
	}
	@keyframes hex-breathe {
		0%,
		100% {
			opacity: 0.06;
		}
		50% {
			opacity: 0.12;
		}
	}

	/* concentric range rings, centered on the viewport */
	.rings {
		position: absolute;
		inset: -20%;
		background: repeating-radial-gradient(
			circle at 50% 50%,
			transparent 0 118px,
			rgba(255, 153, 0, 0.05) 118px 120px
		);
		mask-image: radial-gradient(circle at 50% 50%, #000 0 55%, transparent 78%);
		-webkit-mask-image: radial-gradient(circle at 50% 50%, #000 0 55%, transparent 78%);
	}

	/* rotating radar sweep beam */
	.sweep {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 200vmax;
		height: 200vmax;
		transform: translate(-50%, -50%);
		background: conic-gradient(
			from 0deg,
			rgba(255, 153, 0, 0.14) 0deg,
			rgba(255, 153, 0, 0.04) 18deg,
			transparent 46deg,
			transparent 360deg
		);
		mask-image: radial-gradient(circle at 50% 50%, #000 0 42%, transparent 60%);
		-webkit-mask-image: radial-gradient(circle at 50% 50%, #000 0 42%, transparent 60%);
		animation: sweep-rotate 14s linear infinite;
		will-change: transform;
	}
	@keyframes sweep-rotate {
		to {
			transform: translate(-50%, -50%) rotate(1turn);
		}
	}

	.blips {
		position: absolute;
		inset: 0;
	}
	.blips span {
		position: absolute;
		width: 6px;
		height: 6px;
		margin: -3px 0 0 -3px;
		transform: rotate(45deg);
		animation: blip 4.5s ease-in-out infinite;
	}
	.blips .orange {
		background: var(--nerv-orange);
		box-shadow: 0 0 6px rgba(255, 153, 0, 0.6);
	}
	.blips .cyan {
		background: var(--nerv-cyan);
		box-shadow: 0 0 6px rgba(0, 246, 255, 0.6);
	}
	@keyframes blip {
		0%,
		100% {
			opacity: 0;
			transform: rotate(45deg) scale(0.4);
		}
		50% {
			opacity: 0.7;
			transform: rotate(45deg) scale(1);
		}
	}

	.guide {
		position: absolute;
		top: 0;
		bottom: 0;
		width: 1px;
		background: var(--nerv-line-soft);
	}
</style>
