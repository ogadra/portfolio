---
const BLIPS = [
	{ x: 22, y: 34, c: 'cyan', d: 0 },
	{ x: 78, y: 26, c: 'orange', d: 1.3 },
	{ x: 66, y: 72, c: 'cyan', d: 2.1 },
	{ x: 34, y: 78, c: 'orange', d: 0.7 },
	{ x: 88, y: 58, c: 'cyan', d: 3.2 },
];
---

<div class="nerv-background" aria-hidden="true">
	<svg class="hex-layer" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
		<defs>
			<pattern id="nerv-hex" patternUnits="userSpaceOnUse" width="90" height="51.96">
				<g fill="none" stroke="var(--nerv-orange)" stroke-width="1">
					<polygon points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"></polygon>
					<polygon
						points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"
						transform="translate(90 0)"></polygon>
					<polygon
						points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"
						transform="translate(0 51.96)"></polygon>
					<polygon
						points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"
						transform="translate(90 51.96)"></polygon>
					<polygon
						points="30,0 15,25.98 -15,25.98 -30,0 -15,-25.98 15,-25.98"
						transform="translate(45 25.98)"></polygon>
				</g>
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill="url(#nerv-hex)"></rect>
	</svg>

	<div class="rings"></div>
	<div class="sweep"></div>

	<div class="blips">
		{BLIPS.map((b) => <span class={b.c} style={`left:${b.x}%; top:${b.y}%; animation-delay:${b.d}s`} />)}
	</div>

	<div class="guide" style="left: 12%"></div>
	<div class="guide" style="left: 50%"></div>
	<div class="guide" style="left: 88%"></div>
</div>

<script>
	// scatter the blips like transient radar contacts, moving each to a new
	// random spot every time it fades out
	const rand = (min: number, max: number) => min + Math.random() * (max - min);
	const place = (el: HTMLElement) => {
		el.style.left = `${rand(6, 94)}%`;
		el.style.top = `${rand(8, 92)}%`;
	};
	for (const el of document.querySelectorAll<HTMLElement>('.blips span')) {
		place(el);
		el.addEventListener('animationiteration', () => place(el));
	}

	// pin the radar/rings centre to the subject reticle, measured relative to the
	// scrolling HUD root so it stays aligned as the page scrolls
	const alignRadar = () => {
		const root = document.querySelector<HTMLElement>('.hud-root');
		const stage = document.querySelector<HTMLElement>('.subject .stage');
		if (!root || !stage) return;
		const r = root.getBoundingClientRect();
		const s = stage.getBoundingClientRect();
		root.style.setProperty('--radar-cx', `${s.left + s.width / 2 - r.left}px`);
		root.style.setProperty('--radar-cy', `${s.top + s.height / 2 - r.top}px`);
	};
	alignRadar();
	requestAnimationFrame(alignRadar);
	window.addEventListener('resize', alignRadar);
	window.addEventListener('load', alignRadar);
</script>

<style>
	/* scrolls with the HUD content; radar/rings centre on --radar-cx/cy, which JS
	   pins to the subject reticle */
	.nerv-background {
		position: absolute;
		inset: 0;
		z-index: 0;
		overflow: hidden;
		pointer-events: none;
	}

	.hex-layer {
		position: absolute;
		inset: 0;
		animation: hex-breathe 8s ease-in-out infinite;
	}
	@keyframes hex-breathe {
		0%,
		100% {
			opacity: 0.06;
		}
		50% {
			opacity: 0.12;
		}
	}

	/* concentric range rings — kept to an outer band so they don't collide with
	   the subject reticle in the centre */
	.rings {
		position: absolute;
		inset: 0;
		background: repeating-radial-gradient(
			circle at var(--radar-cx, 50%) var(--radar-cy, 50%),
			transparent 0 118px,
			rgba(255, 153, 0, 0.045) 118px 120px
		);
		mask-image: radial-gradient(
			circle at var(--radar-cx, 50%) var(--radar-cy, 50%),
			transparent 0 46%,
			#000 62%,
			transparent 84%
		);
		-webkit-mask-image: radial-gradient(
			circle at var(--radar-cx, 50%) var(--radar-cy, 50%),
			transparent 0 46%,
			#000 62%,
			transparent 84%
		);
	}

	/* rotating radar sweep beam, centred on the subject reticle */
	.sweep {
		position: absolute;
		left: var(--radar-cx, 50%);
		top: var(--radar-cy, 50%);
		width: 200vmax;
		height: 200vmax;
		transform: translate(-50%, -50%);
		/* bright leading edge at 130deg with the tail ramping up behind it, so a
		   clockwise sweep shows the sharp edge in front and the fade trailing */
		background: conic-gradient(
			from 0deg,
			rgba(255, 153, 0, 0) 0deg,
			rgba(255, 153, 0, 0.08) 96deg,
			rgba(255, 153, 0, 0.2) 130deg,
			transparent 131deg,
			transparent 360deg
		);
		/* covers the centre so the beam sweeps across the subject icon, fading out
		   gently toward the edges so there is no hard ring */
		mask-image: radial-gradient(circle at 50% 50%, #000 0 52%, transparent 88%);
		-webkit-mask-image: radial-gradient(circle at 50% 50%, #000 0 52%, transparent 88%);
		animation: sweep-rotate 16s linear infinite;
		will-change: transform;
	}
	@keyframes sweep-rotate {
		to {
			transform: translate(-50%, -50%) rotate(1turn);
		}
	}

	.blips {
		position: absolute;
		inset: 0;
	}
	.blips span {
		position: absolute;
		width: 6px;
		height: 6px;
		margin: -3px 0 0 -3px;
		transform: rotate(45deg);
		animation: blip 4.5s ease-in-out infinite;
	}
	.blips .orange {
		background: var(--nerv-orange);
		box-shadow: 0 0 6px rgba(255, 153, 0, 0.6);
	}
	.blips .cyan {
		background: var(--nerv-cyan);
		box-shadow: 0 0 6px rgba(67, 213, 220, 0.6);
	}
	@keyframes blip {
		0%,
		100% {
			opacity: 0;
			transform: rotate(45deg) scale(0.4);
		}
		50% {
			opacity: 0.7;
			transform: rotate(45deg) scale(1);
		}
	}

	.guide {
		position: absolute;
		top: 0;
		bottom: 0;
		width: 1px;
		background: var(--nerv-line-soft);
	}
</style>
