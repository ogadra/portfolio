	}
	.brand-name:hover,
	.brand-name:focus-visible {
		text-shadow: 0 0 6px rgba(255, 153, 0, 0.6);
	}
	.brand-name:focus-visible {
		outline: 2px solid var(--nerv-orange);
		outline-offset: 4px;
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 1rem;
		min-width: 0;
	}
	.chip {
		font-family: var(--font-display);
		font-size: clamp(0.5rem, 1.3vw, 0.62rem);
		letter-spacing: 0.25em;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--nerv-orange);
		border: 1px solid var(--nerv-line-strong);
		padding: 0.3em 0.75em;
	}
	.chip:hover,
	.chip:focus-visible {
		background: var(--nerv-orange);
		color: var(--nerv-black);
	}
	.chip:focus-visible {
		outline: 2px solid var(--nerv-orange);
		outline-offset: 3px;
	}

	.clock {
		display: flex;
		gap: 0.7rem;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.15em;
		font-variant-numeric: tabular-nums;
		color: var(--nerv-white);
