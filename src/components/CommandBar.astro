<header class="command-bar">
	<div class="primary">
		<div class="brand">
			<svg class="brand-mark" viewBox="0 0 32 32" aria-hidden="true">
				<polygon
					points="16,2 28.1,9 28.1,23 16,30 3.9,23 3.9,9"
					fill="none"
					stroke="var(--nerv-orange)"
					stroke-width="1.5"></polygon>
				<polygon points="16,9 22.1,20 9.9,20" fill="var(--nerv-orange)"></polygon>
			</svg>
			<div class="brand-text">
				<span class="brand-sub">個人サイト</span>
				<a class="brand-name" href="/">ogadra.com</a>
			</div>
		</div>
		<div class="meta">
			<a class="chip" href="https://github.com/ogadra" rel="me">GitHub</a>
			<a class="chip" href="https://twitter.com/const_myself" rel="me">Twitter</a>
			<span class="clock" aria-hidden="true">
				<span data-hud-date>----.--.--</span>
				<time data-hud-time>--:--:--</time>
			</span>
			<span class="sys-status" aria-hidden="true">SYS<b>NOMINAL</b></span>
		</div>
	</div>
</header>

<script>
	import { formatHudDate, formatHudTime } from '../lib/hudClock';

	const dateEl = document.querySelector('[data-hud-date]');
	const timeEl = document.querySelector('[data-hud-time]');
	const tick = () => {
		const now = new Date();
		if (dateEl) dateEl.textContent = formatHudDate(now);
		if (timeEl) timeEl.textContent = formatHudTime(now);
	};
	tick();
	setInterval(tick, 1000);
</script>

<style>
