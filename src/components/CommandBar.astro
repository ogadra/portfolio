		line-height: 1.1;
	}
	.brand-sub {
		font-family: var(--font-serif-jp);
		font-weight: 900;
		font-size: 0.56rem;
		letter-spacing: 0.5em;
		color: var(--nerv-white);
		opacity: 0.5;
	}
	.brand-name {
		font-family: var(--font-display);
		font-size: 0.95rem;
