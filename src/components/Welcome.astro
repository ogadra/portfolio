---
import { env } from 'cloudflare:workers';
import { fetchGithubStats } from '../lib/github';
import CommandBar from './CommandBar.astro';
import DataReadout from './DataReadout.astro';
import MagiRoles from './MagiRoles.astro';
import NervBackground from './NervBackground.astro';
import StatusTicker from './StatusTicker.astro';
import SubjectDisplay from './SubjectDisplay.astro';

const stats = await fetchGithubStats(env);
---

<div class="hud-root">
	<NervBackground />
	<span class="corner tl" aria-hidden="true"></span>
	<span class="corner tr" aria-hidden="true"></span>
	<span class="corner bl" aria-hidden="true"></span>
	<span class="corner br" aria-hidden="true"></span>

	<CommandBar />
	<main class="hud-main">
		<DataReadout stats={stats} />
		<SubjectDisplay stats={stats} />
		<MagiRoles languages={stats?.languages ?? []} />
	</main>
	<StatusTicker stats={stats} />
</div>

<style>
	.hud-root {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-height: 100dvh;
		padding: 1.4rem;
		position: relative;
	}

	/* keep every real panel above the scrollable background layer */
	.hud-root > header,
	.hud-root > main,
	.hud-root > footer {
		position: relative;
		z-index: 1;
	}

	.corner {
		position: absolute;
		z-index: 1;
		width: 26px;
		height: 26px;
		border: 0 solid var(--nerv-orange);
		opacity: 0.7;
		pointer-events: none;
	}
	.tl {
		top: 8px;
		left: 8px;
		border-top-width: 2px;
		border-left-width: 2px;
	}
	.tr {
		top: 8px;
		right: 8px;
		border-top-width: 2px;
		border-right-width: 2px;
	}
	.bl {
		bottom: 8px;
		left: 8px;
		border-bottom-width: 2px;
		border-left-width: 2px;
	}
	.br {
		bottom: 8px;
		right: 8px;
		border-bottom-width: 2px;
		border-right-width: 2px;
	}

	.hud-main {
		flex: 1;
		display: grid;
		grid-template-columns: 230px minmax(0, 1fr) 290px;
		gap: 1rem;
		align-items: center;
	}
	.hud-main > :global(.readout),
	.hud-main > :global(.magi) {
		align-self: stretch;
		justify-content: center;
	}

	@media (max-width: 1000px) {
		.hud-root {
			padding: 1rem;
		}
		.hud-main {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
		.hud-main > :global(.subject) {
			order: -1;
		}
	}
</style>
