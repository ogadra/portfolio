---
import { m } from '../paraglide/messages.js';
import Typewriter from './Typewriter.astro';

const subjects = ['Front-End', 'Back-End', 'Infrastructure'];
---

<div class="welcome-root">
	<h1>
		{m.welcome_heading_prefix()}<a href="/">ogadra.com</a>{m.welcome_heading_suffix()}
	</h1>
	<div class="table">
		<div class="left">
			<div class="record">
				<Typewriter subjects={subjects} />
				<span class="cursor"></span>
				<p class="role">{m.welcome_role()}</p>
			</div>
		</div>
		<div class="right">
			<div class="jump">
				<img
					class="icon"
					src="/imgs/ogadra.png"
					alt={m.welcome_icon_alt()}
					width="3000"
					height="3300"
				/>
			</div>
		</div>
	</div>
</div>

<style>
	.welcome-root {
		flex-direction: column;
		height: 100vh;
		display: flex;
	}

	h1 {
		font-size: 5vw;
		text-align: center;
		width: 100vw;
		margin: 10vh 0;
	}
	h1 > a {
		font-size: 1em;
	}

	.table {
		display: table;
		width: 100%;
		margin: 0 auto;
	}
	.left {
		display: table-cell;
		width: 60%;
		vertical-align: middle;
	}
	.record {
		text-align: center;
		margin: 8%;
	}

	.record :global(p),
	.record .cursor {
		font-size: max(3vw, 2rem);
		text-align: center;
	}

	.role::first-letter {
		color: #f092ac;
		font-size: max(4.5vw, 3rem);
	}

	.right {
		margin: auto;
		width: min(20vw, 100%);
		height: min(50vw, 480px);
	}

	@keyframes blink {
		0% {
			opacity: 0;
		}
		5% {
			opacity: 1;
		}
		50% {
			opacity: 1;
		}
		55% {
			opacity: 0;
		}
	}

	.record :global(p) {
		display: inline-block;
	}

	.cursor {
		display: inline;
		padding-left: 0.2em;
		background-color: white;
		opacity: 0;
		margin-top: 0.1em;
		margin-left: 0.15em;
		animation: blink 1s ease-in infinite;
	}

	@keyframes rotating {
		0% {
			transform: rotateY(0);
		}
		80% {
			transform: rotateY(1turn);
		}
		100% {
			transform: rotateY(1turn);
		}
	}
	@keyframes jumping {
		0% {
			transform: translateY(0px);
		}
		20% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(-30px);
		}
		80% {
			transform: translateY(0px);
		}
	}

	.icon {
		width: 100%;
		height: 100%;
		animation: rotating 1.5s ease-in-out infinite;
		object-fit: contain;
		margin: auto;
	}
	.jump {
		animation: jumping 1.5s ease-in-out infinite;
		width: 100%;
		height: 100%;
	}
</style>
