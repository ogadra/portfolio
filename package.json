{
	"name": "portfolio",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build && node scripts/postbuild.mjs",
		"preview": "wrangler dev --config dist/server/wrangler.json",
		"check": "astro check && vp check",
		"test": "vp test",
		"test:e2e": "playwright test",
		"lint": "vp check",
		"format": "vp check --fix",
		"deploy": "pnpm build && wrangler deploy --config dist/server/wrangler.json",
		"astro": "astro"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/cloudflare": "^14.0.2",
		"@inlang/paraglide-js": "^2.20.2",
		"astro": "^7.0.4"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"typescript": "^6.0.3",
		"vite-plus": "^0.2.1",
		"vitest": "^4.1.9",
		"wrangler": "^4.106.0"
	},
	"engines": {
		"node": ">=24.16.0"
	},
	"packageManager": "pnpm@11.9.0"
}
